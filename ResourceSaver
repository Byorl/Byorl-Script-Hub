local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")

local defaultFpsCap = 60
local unfocusedFpsCap = 5

if getgenv().fpscap == nil then
    getgenv().fpscap = defaultFpsCap
end

local hasSetFpsCap = type(setfpscap) == "function"
if not hasSetFpsCap then
    warn("[Performance Script] 'setfpscap' is not supported on your executor.")
end

local function SafeSetFpsCap(cap)
    if hasSetFpsCap then
        pcall(setfpscap, cap)
    end
end

local function ApplySettings(isFocused)
    pcall(function()
        RunService:Set3dRenderingEnabled(isFocused)
    end)

    if isFocused then
        SafeSetFpsCap(getgenv().fpscap)
    else
        SafeSetFpsCap(unfocusedFpsCap)
    end
end

UserInputService.WindowFocused:Connect(function()
    ApplySettings(true)
end)

UserInputService.WindowFocusReleased:Connect(function()
    ApplySettings(false)
end)

ApplySettings(true)
