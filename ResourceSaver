local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

local maxActiveFps = 60
local inactiveFps = 15

local function onTabbedOut()
    pcall(function()
        RunService:Set3dRenderingEnabled(false)
    end)
    
    if setfpscap then
        setfpscap(inactiveFps)
    end
end

local function onTabbedIn()
    pcall(function()
        RunService:Set3dRenderingEnabled(true)
    end)
    
    if setfpscap then
        setfpscap(maxActiveFps)
    end
end

UserInputService.WindowFocusReleased:Connect(onTabbedOut)
UserInputService.WindowFocused:Connect(onTabbedIn)

onTabbedOut()
