local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

local maxActiveFps = 60
local inactiveFps = 15

local function onTabbedOut()
    if setfpscap then
        setfpscap(inactiveFps)
    end
end

local function onTabbedIn()
    if setfpscap then
        setfpscap(maxActiveFps)
    end
end

UserInputService.WindowFocusReleased:Connect(onTabbedOut)
UserInputService.WindowFocused:Connect(onTabbedIn)

if not UserInputService:GetFocused() then
    onTabbedOut()
end
