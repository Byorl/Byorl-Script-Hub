local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")

local defaultFpsCap = 60
local unfocusedFpsCap = 15

if getgenv().PerformanceScriptConnections then
    for _, connection in pairs(getgenv().PerformanceScriptConnections) do
        connection:Disconnect()
    end
end
getgenv().PerformanceScriptConnections = {}

if getgenv().fpscap == nil then
    getgenv().fpscap = defaultFpsCap
end

local hasSetFpsCap = type(setfpscap) == "function"

local function SafeSetFpsCap(cap)
    if hasSetFpsCap then
        pcall(setfpscap, cap)
    end
end

local function ApplySettings(isFocused)
    pcall(function()
        RunService:Set3dRenderingEnabled(isFocused)
    end)

    if isFocused then
        SafeSetFpsCap(getgenv().fpscap)
    else
        SafeSetFpsCap(unfocusedFpsCap)
    end
end

table.insert(getgenv().PerformanceScriptConnections, UserInputService.WindowFocused:Connect(function()
    ApplySettings(true)
end))

table.insert(getgenv().PerformanceScriptConnections, UserInputService.WindowFocusReleased:Connect(function()
    ApplySettings(false)
end))

ApplySettings(UserInputService:GetFocusedWidget() ~= nil)
